# ============================================================
# Zarat Faza 2 - konfiqurasiya SABLONU
# Bu fayli kopyalayib .env adlandirin ve oz deyerlerinizi yazin:
#   cp 01_config/.env.numune 01_config/.env
# ============================================================

# --- Zavod (edge) bazasi - ZAVOD MAC-inda localhost ---
EDGE_DB_HOST=localhost
EDGE_DB_PORT=5434
EDGE_DB_NAME=zavod_edge_db
EDGE_DB_USER=royatalibova

# --- Merkezi baza (zarat_erp_2) ---
# DIQQET: iki main olanda buran MERKEZI MAC-in IP unvani edin
# meselen: MERKEZ_DB_HOST=192.168.1.50
MERKEZ_DB_HOST=192.168.1.68
MERKEZ_DB_PORT=5432
MERKEZ_DB_NAME=zarat_erp_2
MERKEZ_DB_USER=zavod_sync

# --- MQTT broker (ZAVOD MAC-inda localhost) ---
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_BASE=zavod/siyezen
MERKEZ_DB_PASSWORD=Siyezen2026Zarat

# --- Sync (Ders 07) ---
ZAVOD_KOD=SIYEZEN
SYNC_INTERVAL=10
SYNC_BATCH_OLCME=500
SYNC_BATCH_ALERT=100
SYNC_ALERT_TEKRAR=60
ANTHROPIC_API_KEY=sk-ant-...
